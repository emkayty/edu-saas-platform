# Frontend Environment Variables
# ====================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Authentication
NEXT_PUBLIC_TOKEN_KEY=edusaas_access_token
NEXT_PUBLIC_REFRESH_TOKEN_KEY=edusaas_refresh_token

# Feature Flags
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_MOBILE_APP=true

# Upload
NEXT_PUBLIC_MAX_UPLOAD_SIZE=10485760
NEXT_PUBLIC_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Theme Defaults
NEXT_PUBLIC_DEFAULT_THEME=traditional-blue

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_GA_TRACKING_ID=

# Support
NEXT_PUBLIC_SUPPORT_EMAIL=support@edusaas.com
NEXT_PUBLIC_SUPPORT_PHONE=+2347000000000