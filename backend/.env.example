# Backend Environment Variables
# ====================================

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database - PostgreSQL (Supabase)
DB_TYPE=postgres
DB_HOST=db.mspzofdentgahfbkusbc.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=ssrNGXEIqvkKjaKj
DB_DATABASE=postgres
DB_SSL=true

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Remita Payment Gateway (Nigeria)
REMITA_MERCHANT_ID=your-merchant-id
REMITA_API_KEY=your-api-key
REMITA_SERVICE_TYPE_ID=your-service-type-id
REMITA_BASE_URL=https://remita.com
REMITA_CALLBACK_URL=http://localhost:3001/api/v1/integrations/remita/webhook

# JAMB CAPS Integration
JAMB_CAPS_BASE_URL=https://caps.jamb.gov.ng/api/v1
JAMB_INSTITUTION_CODE=your-institution-code
JAMB_API_KEY=your-jamb-api-key
JAMB_SECRET_KEY=your-jamb-secret-key

# NUC/NBTE Reporting
NUC_API_KEY=your-nuc-api-key
NBTE_API_KEY=your-nbte-api-key
INSTITUTION_CODE=your-institution-code

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=EduSaaS <noreply@edusaas.com.ng>

# SMS Configuration (Nigeria)
SMS_PROVIDER=TERMII
TERMII_API_KEY=your-termii-api-key

# File Storage
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_DESTINATION=./uploads

# AI/ML Service (Python)
PYTHON_AI_SERVICE_URL=http://localhost:8000
PYTHON_AI_SERVICE_TIMEOUT=30000

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs
LOG_MAX_FILES=7

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=your-session-secret-min-32-chars