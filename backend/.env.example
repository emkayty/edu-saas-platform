# Backend Environment Variables
# ====================================

# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=edusaas
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Remita Payment Gateway (Nigeria)
REMITA_MERCHANT_ID=your-merchant-id
REMITA_API_KEY=your-api-key
REMITA_BASE_URL=https://remita-api-url

# JAMB Integration
JAMB_BASE_URL=https://caps.jamb.gov.ng
JAMB_API_KEY=your-jamb-api-key

# NUC/NBTE Reporting
NUC_API_KEY=your-nuc-api-key
NBTE_API_KEY=your-nbte-api-key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=EduSaaS <noreply@edusaas.com>

# SMS Configuration (Nigeria)
SMS_PROVIDER=TERMII
TERMII_API_KEY=your-termii-api-key

# File Storage
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# AI/ML Service
PYTHON_AI_SERVICE_URL=http://localhost:8000

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Security
CORS_ORIGIN=http://localhost:3001
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX_REQUESTS=100