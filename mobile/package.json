{
  "name": "edu-saas-mobile",
  "version": "1.0.0",
  "description": "EduSaaS Mobile Application for universities and polytechnics",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "xcodebuild -workspace ios/EduSaas.xcworkspace -scheme EduSaas -configuration Release build",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "prebuild": "react-native prebuild"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@react-navigation/stack": "^6.4.1",
    "axios": "^1.7.0",
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "react-native-gesture-handler": "^2.20.0",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^4.0.0",
    "react-native-reanimated": "^3.15.0",
    "react-native-worklets": "^0.1.0",
    "react-native-vector-icons": "^10.2.0",
    "zustand": "^4.5.5",
    "react-native-mmkv": "^3.0.0",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "^0.76.0",
    "@react-native/eslint-config": "^0.76.0",
    "@react-native/metro-config": "^0.76.0",
    "@react-native/typescript-config": "^0.76.0",
    "@types/react": "^18.3.4",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^18.3.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "react-test-renderer": "^18.3.1",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
}